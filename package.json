		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-intersection-observer": "^10.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@playwright/test": "^1.60.0",
		"@tailwindcss/postcss": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
